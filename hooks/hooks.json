{
  "_comment": "k0d3 hooks. The 10 wired below are enabled by default (old-claude parity + ensure-memory-gitignore, all safe globally). The 3 in _disabled_examples are k0d3-repo-dev-specific and opt-in. Paths use ${CLAUDE_PLUGIN_ROOT} so they resolve in any project regardless of the user's cwd. See docs/hooks-migration.md.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/guard-bash.sh" }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/backup-before-write.sh" },
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/completeness-gate.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/log-changes.sh" }]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/log-failures.sh" }]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/pre-compact-handoff.sh" }]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/session-reset.sh" },
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/ensure-memory-gitignore.sh" }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/post-compact-resume.sh" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/log-stop-verdict.sh" }]
      }
    ]
  },
  "_disabled_examples": {
    "_doc": "Opt-in / k0d3-repo-dev-specific hooks. To enable one, add a nested entry under the matching hooks.<event> array above: a matcher plus a hooks[] list whose command is \"${CLAUDE_PLUGIN_ROOT}\"/hooks/<name>.sh. The flat objects below are catalog notation, NOT valid live config.",
    "validate-skill-frontmatter": {
      "event": "PreToolUse",
      "matcher": "Write|Edit",
      "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/validate-skill-frontmatter.sh"
    },
    "check-name-collisions": {
      "event": "SessionStart",
      "matcher": "startup",
      "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/check-name-collisions.sh"
    },
    "block-deferred-issues": {
      "event": "PreToolUse",
      "matcher": "Bash",
      "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/block-deferred-issues.sh"
    }
  }
}
